# ── Turso database ───────────────────────────────────────────────
# Create a database with the Turso CLI first:
#   turso auth login
#   turso db create tvr-dubbers
#   turso db show tvr-dubbers          → gives you TURSO_DATABASE_URL
#   turso db tokens create tvr-dubbers → gives you TURSO_AUTH_TOKEN
#
# Leave both blank to run locally against a local SQLite file
# (backend/local.db) — same @libsql/client, zero cloud setup, good
# for development. Fill them in for the real Render deployment.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Auth ─────────────────────────────────────────────────────────
# Any long random string — e.g. generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Password used ONLY the first time `npm run seed` creates the admin
# account. Leave blank and the seed script will generate a strong
# random one and print it once — either way, change it from the
# admin panel after your first login.
ADMIN_SEED_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────
# Your deployed Netlify URL, no trailing slash. Needed so the
# browser is allowed to call this API from the frontend's origin.
FRONTEND_ORIGIN=https://your-site.netlify.app

# ── Server ───────────────────────────────────────────────────────
PORT=3000
